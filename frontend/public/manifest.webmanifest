{
  "name": "paisa — expense tracker",
  "short_name": "paisa",
  "description": "Track daily spend, platform fees, and budgets.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0B0B0D",
