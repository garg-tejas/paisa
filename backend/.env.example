# ---- paisa backend environment ----
# Copy to .env and fill in. Never commit the real .env.

# Postgres connection string (Neon / Railway / local).
# Local docker-compose default:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paisa
# Neon example:
# DATABASE_URL=postgresql://user:pass@ep-xxxx.ap-southeast-1.aws.neon.tech/paisa?sslmode=require

# Z.ai GLM API key — powers image OCR (glm-ocr) + receipt structuring (glm-4.7-flash).
# Image parsing returns 503 until this is set; manual entry still works.
GLM_API_KEY=

# Web Push (VAPID). Generate a keypair (see backend/README.md).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=tejas@tejasgarg.in

# CORS: comma-separated allowed origins, or * for all (default).
# e.g. CORS_ORIGINS=https://paisa.vercel.app,http://localhost:3000
CORS_ORIGINS=*

# Port (Railway sets $PORT automatically; default 8000 locally).
PORT=8000
